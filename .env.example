# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangSmith Tracing
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=accesslens
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# NCBI / PubMed
# Required by Entrez API guidelines — use your real email address
NCBI_EMAIL=your_email@example.com

# Qdrant
QDRANT_PATH=./qdrant_data

# Application
ACCESSLENS_LOG_LEVEL=INFO
ACCESSLENS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
